

def can_use_color(node, color, graph, colors):
    for neighbor in graph[node]:
        if colors[neighbor] == color:
            return False
    return True


def solve_coloring(node, n, k, graph, colors):
    if node == n:
        return True

    for color in range(1, k + 1):
        if can_use_color(node, color, graph, colors):
            colors[node] = color
            if solve_coloring(node + 1, n, k, graph, colors):
                return True
            colors[node] = 0

    return False


def graph_coloring(n, m, k, edges):
    graph = [[] for _ in range(n)]

    for u, v in edges:
        graph[u].append(v)
        graph[v].append(u)

    colors = [0] * n

    if solve_coloring(0, n, k, graph, colors):
        return True, colors
    return False, []


with open("input.txt", "r") as file:
    lines = [line.strip() for line in file if line.strip()]

index = 0

while index < len(lines):
    n, m, k = map(int, lines[index].split())
    index += 1

    edges = []
    for _ in range(m):
        u, v = map(int, lines[index].split())
        edges.append((u, v))
        index += 1

    possible, assignment = graph_coloring(n, m, k, edges)

    if possible:
        print(f"Coloring Possible with {k} Colors")
        print(f"Color Assignment: {assignment}")
    else:
        print(f"Coloring Not Possible with {k} Colors")

    if index < len(lines):
        print()
